// 評級系統
function getRank(score) {
    if (score >= 300) return "無敵";
    if (score >= 270) return "很強";
    if (score >= 180) return "強";
    if (score >= 120) return "正常";
    if (score >= 0) return "弱";
    return "滅國";
}

// 遊戲邏輯
function initGame() {
    try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    } catch(e) {}
    document.getElementById("score-display").innerHTML = "";
    goToNode("start");
}

function goToNode(nodeId) {
    const node = storyData[nodeId];
    const contentBox = document.getElementById("content-box");
    const gameImg = document.getElementById("game-image");
    const titleEl = document.getElementById("story-title");
    const textEl = document.getElementById("story-text");
    const optionsEl = document.getElementById("options-container");
    const scoreEl = document.getElementById("score-display");

    // 觸發文字與選項動畫
    contentBox.classList.remove("fade-in");
    void contentBox.offsetWidth; // 觸發重繪
    contentBox.classList.add("fade-in");

    // 設定圖片
    gameImg.style.opacity = 0; // 先淡出
    setTimeout(() => {
        // 修改 src。如果圖片不存在，瀏覽器會顯示默認樣式或 alt 文字
        gameImg.src = node.bgImage; 
        gameImg.classList.remove("img-placeholder");
        // 圖片載入完成後淡入 (處理如果圖片路徑出錯的情況)
        gameImg.onload = () => gameImg.style.opacity = 1;
        gameImg.onerror = () => {
            gameImg.classList.add("img-placeholder");
            gameImg.alt = "图片 [" + node.bgImage + "] 未找到 - 請閱讀代碼註釋以添加圖片";
            gameImg.style.opacity = 1;
        };
    }, 200);

    // 設定文字
    titleEl.innerHTML = node.title;
    textEl.innerHTML = node.text;
    optionsEl.innerHTML = "";
    
    // 如果是結局
    if (node.score !== undefined) {
        playSound(node.isWin ? 'win' : 'lose');
        
        let rankStr = getRank(node.score);
        let color = node.isWin ? "#ffcc00" : "#ff4444";
        scoreEl.innerHTML = "最終評價：<span style='color:" + color + ";'>" + rankStr + " (" + node.score + "分)</span>";

        let restartBtn = document.createElement("button");
        restartBtn.className = "btn";
        restartBtn.style.background = "linear-gradient(180deg, #444, #222)";
        restartBtn.innerText = "重新開始";
        restartBtn.onclick = function() {
            playSound('click');
            initGame();
        };
        optionsEl.appendChild(restartBtn);
    } else {
        // 如果是事件
        playSound('click');

        node.options.forEach(opt => {
            let btn = document.createElement("button");
            btn.className = "btn";
            btn.innerText = opt.text;
            btn.onclick = function() {
                playSound('click');
                goToNode(opt.next);
            };
            optionsEl.appendChild(btn);
        });
    }
}
</script>
