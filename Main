// 評級系統
function getRank(score) {
    if (score >= 300) return "無敵 (300分)";
    if (score >= 270) return "很強 (" + score + "分)";
    if (score >= 180) return "強 (" + score + "分)";
    if (score >= 120) return "正常 (" + score + "分)";
    if (score >= 0) return "弱 (" + score + "分)";
    return "滅國 (-100分)";
}

// 遊戲邏輯
function initGame() {
    // 為了允許瀏覽器播放音效，必須由使用者點擊後初始化 AudioContext
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    document.getElementById("score-display").innerHTML = "";
    goToNode("start");
}

function goToNode(nodeId) {
    const node = storyData[nodeId];
    const container = document.getElementById("game-container");
    const visualBox = document.getElementById("visual-box");
    const titleEl = document.getElementById("story-title");
    const textEl = document.getElementById("story-text");
    const optionsEl = document.getElementById("options-container");
    const scoreEl = document.getElementById("score-display");

    // 觸發動畫
    container.classList.remove("fade-in");
    void container.offsetWidth; // 觸發重繪
    container.classList.add("fade-in");

    // 設定文字與畫面
    titleEl.innerHTML = node.title;
    textEl.innerHTML = node.text;
    optionsEl.innerHTML = "";
    
    // 如果是結局
    if (node.score !== undefined) {
        visualBox.style.background = node.isWin ? "linear-gradient(45deg, #F1C40F, #D35400)" : "linear-gradient(45deg, #2C3E50, #000000)";
        visualBox.innerText = node.isWin ? "🏆 歷史的勝利者" : "💀 歷史的塵埃";
        playSound(node.isWin ? 'win' : 'lose');
        
        let rankStr = getRank(node.score);
        scoreEl.innerHTML = "最終評價：<span style='color:white;'>" + rankStr + "</span>";

        let restartBtn = document.createElement("button");
        restartBtn.className = "btn";
        restartBtn.innerText = "重新開始";
        restartBtn.onclick = function() {
            playSound('click');
            initGame();
        };
        optionsEl.appendChild(restartBtn);
    } else {
        // 如果是事件
        visualBox.style.background = node.color;
        visualBox.innerText = "抉擇時刻";
        playSound('click');

        node.options.forEach(opt => {
            let btn = document.createElement("button");
            btn.className = "btn";
            btn.innerText = opt.text;
            btn.onclick = function() {
                playSound('click');
                goToNode(opt.next);
            };
            optionsEl.appendChild(btn);
        });
    }
}
</script>
